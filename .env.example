# Copy this file to .env and set your values.
# All three variables are required for login and sync to work.

# Username and password for the in-app login screen.
APP_USER=replace-with-your-username
APP_PASSWORD=replace-with-a-strong-password

# Sync API token — internal secret used to authenticate sync requests.
# Never shown to the user; returned by the server after successful login.
# Generate with: openssl rand -hex 32
SYNC_TOKEN=replace-with-your-secret-token

# (Optional) Restrict CORS to a specific origin. Recommended for production.
# Set to the URL you access the app from, e.g. http://192.168.1.50:7777
# Leave blank to allow all origins (fine for local dev or trusted networks).
CORS_ORIGIN=
