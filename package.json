{
  "name": "pok-dex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-data": "tsx --tsconfig tsconfig.scripts.json scripts/fetch-data.ts",
    "merge-stats": "tsx --tsconfig tsconfig.scripts.json scripts/merge-stats.ts",
    "patch-slot2": "tsx --tsconfig tsconfig.scripts.json scripts/patch-slot2.ts",
    "fetch-battle-tower": "tsx --tsconfig tsconfig.scripts.json scripts/fetch-battle-tower.ts",
    "ios:sync": "npx cap sync ios",
    "ios:icons": "npx capacitor-assets generate --ios",
    "generate:icon": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "zustand": "^5.0.12"
  }
}
